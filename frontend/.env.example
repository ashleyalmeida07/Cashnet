# API Configuration
# For production (Vercel), set this in your Vercel project environment variables
# For local development, copy this to .env.local and use localhost
NEXT_PUBLIC_API_URL=https://cash-net.onrender.com

# WalletConnect Project ID (if using RainbowKit/WalletConnect)
# Get yours at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional: Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
