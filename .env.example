# ── Deployer wallet ─────────────────────────────────────────────────────────
# Your private key (with or without 0x prefix). NEVER commit this file.
PRIVATE_KEY=your_private_key_here

# ── Sepolia RPC ──────────────────────────────────────────────────────────────
# Get a free endpoint from Infura (infura.io) or Alchemy (alchemy.com)
# Infura:  https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ── Etherscan (optional) ─────────────────────────────────────────────────────
# Used for contract verification info. Get at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Deployed Contracts (Sepolia) ─────────────────────────────────────────────
# Fill these in after running the deployment script.
ACCESS_CONTROL_ADDRESS=0x0000000000000000000000000000000000000000
SIM_TOKEN_A_ADDRESS=0x0000000000000000000000000000000000000000
SIM_TOKEN_B_ADDRESS=0x0000000000000000000000000000000000000000
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CREDIT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
LENDING_POOL_ADDRESS=0x0000000000000000000000000000000000000000
LIQUIDITY_POOL_ADDRESS=0x0000000000000000000000000000000000000000
