# ── Deployer wallet ─────────────────────────────────────────────────────────
# Your private key (with or without 0x prefix). NEVER commit this file.
PRIVATE_KEY=your_private_key_here

# ── Sepolia RPC ──────────────────────────────────────────────────────────────
# Get a free endpoint from Infura (infura.io) or Alchemy (alchemy.com)
# Infura:  https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ── Etherscan (optional) ─────────────────────────────────────────────────────
# Used for contract verification info. Get at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Deployed Contracts (Sepolia) ─────────────────────────────────────────────
# Fill these in after running the deployment script.
ACCESS_CONTROL_ADDRESS=0x0000000000000000000000000000000000000000
SIM_TOKEN_A_ADDRESS=0x0000000000000000000000000000000000000000
SIM_TOKEN_B_ADDRESS=0x0000000000000000000000000000000000000000
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CREDIT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
LENDING_POOL_ADDRESS=0x0000000000000000000000000000000000000000
LIQUIDITY_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cashnet

# ── Firebase (Frontend SDK) ────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Project Settings → General → Your apps → Web app → SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ── Firebase Admin SDK (Backend) ───────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key

# ── Groq AI (Smart Contract Analyzer) ────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Save the downloaded JSON file, then set its path here (absolute or relative to backend/)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── JWT (Backend session tokens) ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Operator provisioning secret ───────────────────────────────────────────
# Used to call POST /auth/provision to add Admin/Auditor accounts
PROVISION_SECRET=change-this-to-a-secret-string

# ── Frontend API URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
